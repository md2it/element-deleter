# Canonical gitignore: ALL-PRJ-REQ/.gitignore

# --- PROJECT-SPECIFIC RULES ---------------------------------------------------

# --- USER-SPECIFIC RULES ------------------------------------------------------

# Personal Working Files
docs/publication/checklist.md

# AI and LLM Tools
.cursor/
.claude/

# Temporary Files
tmp/
temp/
temp*.md
TEMP*.md
*.local


# --- TECHNOLOGY-SPECIFIC RULES ------------------------------------------------

# Dependencies
node_modules/

# Environment and Secrets
.env
.env.*
!.env.example
*.pem
!public-key.pem
*.key
!public-key.key
credentials.json
secrets.json
.envrc

# Build Outputs
dist/
build/
out/

# Distribution Archives
*.zip

# Tests and Coverage
coverage/

# Browser Test Artifacts
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Logs and Debug
logs/
*.log
npm-debug.log*

# npm Cache
.npm-cache/


# --- UNIVERSAL RULES ----------------------------------------------------------

# Operating System Files
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Caches
.cache/
