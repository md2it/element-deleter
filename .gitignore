# Canonical gitignore: ALL-PRJ-REQ/.gitignore

# --- PROJECT-SPECIFIC RULES ---------------------------------------------------

# Publication Assets
PUBLICATION/*.png
PUBLICATION/**/*.png
PUBLICATION/*.jpeg
PUBLICATION/**/*.jpeg
PUBLICATION/*.jpg
PUBLICATION/**/*.jpg

# --- USER-SPECIFIC RULES ------------------------------------------------------

# Personal Working Files
PUBLICATION/checklist.md

# AI and LLM Tools
.cursor/
.claude/

# Temporary Files
tmp/
temp/
temp*.md
TEMP*.md
*.local


# --- TECHNOLOGY-SPECIFIC RULES ------------------------------------------------

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment and Secrets
.env
.env.*
!.env.example
*.pem
!public-key.pem
*.key
!public-key.key
credentials.json
secrets.json
.envrc

# Build Outputs
dist/
build/
out/
.next/
.nuxt/
.output/
*.tsbuildinfo

# Browser Extension Bundles
/background.js
/content.js
/welcome.js
/blocked-notice.js

# Distribution Archives
*.zip

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Tests and Coverage
coverage/
.nyc_output/

# Browser Test Artifacts
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Logs and Debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# npm Cache
.npm-cache/


# --- UNIVERSAL RULES ----------------------------------------------------------

# Operating System Files
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Caches
.cache/
